# Secrets
.env
*.key
*.pem
auth_config.yaml

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data — too big and/or messy to commit; reproducible from scripts
data/raw/
data/cleaned/
data/interim/
data/jobs/
*.parquet
*.csv
!data/samples/*.csv

# Editors / OS
.vscode/
.idea/
.DS_Store

# Logs / reports (regenerate each run)
logs/
*.log
reports/*.json
!reports/.gitkeep

# Streamlit
.streamlit/secrets.toml
# allow .streamlit/config.toml and .streamlit/secrets.example.toml
!.streamlit/config.toml
!.streamlit/secrets.example.toml

# AWS SAM build artifacts
.aws-sam/
