# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must never be committed.

# --------------------------------------------------------------------------- #
# LLM
# --------------------------------------------------------------------------- #

# Groq — free tier API key from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Future providers (uncomment when added)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# --------------------------------------------------------------------------- #
# Database (v3.0)
# --------------------------------------------------------------------------- #

# Postgres connection string (Supabase URI mode).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
# Leave blank locally to fall back to SQLite at data/datapolish.db.
DATABASE_URL=

# --------------------------------------------------------------------------- #
# Email (v3.2 magic-link)
# --------------------------------------------------------------------------- #

# Resend API key. Get from https://resend.com → API Keys.
RESEND_API_KEY=

# Sender shown on magic-link emails.
#   - dev / test:   onboarding@resend.dev  (only delivers to your own Resend
#                   account email — useful for sanity checks, never real users)
#   - production:   noreply@<your-verified-domain>
#                   e.g. noreply@contact.datapolish.com
# See docs/resend_domain.md for how to verify a domain.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Set DEV_MODE=true to print magic-link codes to the API console instead
# of relying on Resend delivery. Useful when:
#   - Resend isn't fully configured (no verified domain yet)
#   - Your Resend test-sender restriction is blocking deliveries
#   - You want to test the magic-link flow without round-tripping email
# REMOVE / unset this in production.
DEV_MODE=

# --------------------------------------------------------------------------- #
# Auth (v3.1)
# --------------------------------------------------------------------------- #

# JWT signing secret. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Rotate to invalidate every existing session.
JWT_SECRET=

# --------------------------------------------------------------------------- #
# Observability (v3.7)
# --------------------------------------------------------------------------- #

# Sentry DSN — paste from https://sentry.io project settings. Leave blank
# to disable Sentry entirely (app still runs, just no error tracking).
SENTRY_DSN=

# Free-text environment tag attached to every Sentry event. Recommended:
# `production`, `staging`, or `development`. Defaults to `development`.
DATAPOLISH_ENV=development

# Optional release tag (e.g. a git SHA) so Sentry can group errors by
# deploy. Render injects RENDER_GIT_COMMIT — feel free to map it here.
DATAPOLISH_RELEASE=

# Fraction of requests (0.0–1.0) that get a perf trace sent to Sentry.
# 0.1 is a sensible default for the free tier.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Python logging level for the API. INFO in prod, DEBUG locally if you
# want chattier output. Valid: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# --------------------------------------------------------------------------- #
# CORS (v2.6)
# --------------------------------------------------------------------------- #

# Comma-separated origins allowed to call the API. Local dev origins are
# always included. Add your deployed Streamlit URL here, e.g.:
#   ALLOWED_ORIGINS=https://data-polish.streamlit.app
ALLOWED_ORIGINS=
